{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "史莱姆区块扫描器",
  "version": "0.1.0",
  "identifier": "com.jobber.slime-calculator",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "史莱姆区块扫描器",
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 650,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "nsis", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bin/*": "bin/"
    }
  }
}
